# Database Configuration
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=rag_database
POSTGRES_HOST=db
POSTGRES_PORT=5432

# FastAPI API Configuration
API_PORT=8000
EMBEDDING_MODEL_NAME=sentence-transformers/all-MiniLM-L6-v2

# OpenAI Configuration (Optional - leave empty for mock LLM / offline QA)
OPENAI_API_KEY=

# Airflow UID (on Linux, set to current user ID to avoid file permission issues. e.g., run `id -u` and set here)
AIRFLOW_UID=50000

# Path to shared data directory (inside containers)
DATA_DIR=/app/data
